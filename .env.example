# AgentHub — Environment Configuration
# Copy this file to .env and adjust values for your setup.

# === Hermes API Server ===
# URL of the Hermes API Server (runtime, jobs, sessions, streaming)
HERMES_URL=http://localhost:8642

# === Exploration API ===
# URL of the AgentHub Exploration API (system overview, templates)
EXPLORE_URL=http://localhost:8643

# === Hermes Home Directory ===
# Path to Hermes config/profiles/hooks directory
# Defaults to ~/.hermes if not set
HERMES_HOME=${HOME}/.hermes

# === API Key (optional) ===
# If your Hermes instance requires authentication
API_KEY=

# === Frontend ===
# These are consumed by Next.js at build time (NEXT_PUBLIC_ prefix)
# They are also used by demo.sh and start.sh
NEXT_PUBLIC_HERMES_URL=http://localhost:8642
NEXT_PUBLIC_EXPLORE_URL=http://localhost:8643
NEXT_PUBLIC_API_KEY=

# === CORS ===
# Frontend origin(s) allowed to access the Exploration API
# Comma-separated if multiple
CORS_ORIGINS=http://localhost:3000